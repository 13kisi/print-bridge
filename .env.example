# Print Bridge — kasa PC'sinde çalışan localhost servis konfigürasyonu

# Bridge'in dinleyeceği port (localhost only)
PORT=9100

# Yazıcı türü: epson | star
PRINTER_TYPE=epson

# Yazıcı arayüzü:
#   - USB (Windows default printer): printer:auto
#   - USB (named):                   printer:Gainscha GA-E200I
#   - LAN/Wi-Fi:                     tcp://192.168.1.50:9100
#
# USB modu (printer:...) Windows'ta winspool.drv RAW print yöntemi kullanır
# (PowerShell üzerinden, native paket gerektirmez). TCP modu pure-JS Node net
# socket kullanır. İkisi de derleme/Python gerektirmez.
PRINTER_INTERFACE=printer:auto

# Kâğıt genişliği (mm): 80 | 58
PAPER_WIDTH=80

# Satır başına karakter sayısı:
#   - 80mm + Font A: 48
#   - 58mm + Font A: 32
CHARS_PER_LINE=48

# CORS allowlist — virgülle ayrılmış origin listesi.
# Production URL + local dev olmalı.
ALLOWED_ORIGINS=https://pizzapia.com.tr,http://localhost:3000
