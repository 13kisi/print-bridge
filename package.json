{
  "name": "pizza-pia-print-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Pizza Pia için kasa PC'sinde çalışan localhost print bridge — web admin'in HTTP POST ettiği sipariş JSON'unu ESC/POS ile termal yazıcıya gönderir.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "package:win": "pkg dist/server.js --targets node18-win-x64 --output bin/pizza-pia-print-bridge.exe",
    "test:print": "curl -X POST http://localhost:9100/print -H \"Content-Type: application/json\" -d @test-payload.json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-thermal-printer": "^4.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "pkg": "^5.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
